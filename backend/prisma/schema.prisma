generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  BEING_PACKED
  AWAITING_SHIPMENT
  BEING_SHIPPED
  ORDER_COMPLETED
  RETURNED
}

enum DeliveryMethod {
  INSTANT
  NEXT_DAY
  REGULAR
}

enum TransactionType {
  TOP_UP
  CHECKOUT
  REFUND
}

enum DiscountType {
  VOUCHER
  PROMO
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  username     String   @unique @db.VarChar(50)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  roles         UserRole[]
  sellerProfile SellerProfile?
  buyerProfile  BuyerProfile?
  driverProfile DriverProfile?

  @@map("users")
}

model Role {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(20)

  users UserRole[]

  @@map("roles")
}

model UserRole {
  userId String @map("user_id") @db.Uuid
  roleId Int    @map("role_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model ApplicationReview {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reviewerName String   @map("reviewer_name") @db.VarChar(100)
  rating       Int
  comment      String   @db.Text
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  @@map("application_reviews")
}

model SellerProfile {
  userId    String  @id @map("user_id") @db.Uuid
  storeName String? @unique @map("store_name") @db.VarChar(100)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  products Product[]
  carts    Cart[]
  orders   Order[]

  @@map("seller_profiles")
}

model BuyerProfile {
  userId          String  @id @map("user_id") @db.Uuid
  walletBalance   Decimal @default(0.00) @map("wallet_balance") @db.Decimal(12, 2)
  deliveryAddress String? @map("delivery_address") @db.Text

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  cart               Cart?
  orders             Order[]
  walletTransactions WalletTransaction[]

  @@map("buyer_profiles")
}

model DriverProfile {
  userId   String  @id @map("user_id") @db.Uuid
  earnings Decimal @default(0.00) @map("earnings") @db.Decimal(12, 2)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  deliveryJobs DeliveryJob[]

  @@map("driver_profiles")
}

model Product {
  id       String        @id @default(uuid()) @db.Uuid
  sellerId String        @map("seller_id") @db.Uuid
  seller   SellerProfile @relation(fields: [sellerId], references: [userId], onDelete: Cascade)

  name        String  @db.VarChar(255)
  description String? @db.Text
  price       Decimal @db.Decimal(10, 2)
  stock       Int     @default(0)
  isActive    Boolean @default(true) @map("is_active")

  cartItems  CartItem[]
  orderItems OrderItem[]

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  @@map("products")
}

model Cart {
  id      String       @id @default(uuid()) @db.Uuid
  buyerId String       @unique @map("buyer_id") @db.Uuid
  buyer   BuyerProfile @relation(fields: [buyerId], references: [userId], onDelete: Cascade)

  sellerId String?        @map("seller_id") @db.Uuid
  seller   SellerProfile? @relation(fields: [sellerId], references: [userId])

  items CartItem[]

  @@map("carts")
}

model CartItem {
  id        String  @id @default(uuid()) @db.Uuid
  cartId    String  @map("cart_id") @db.Uuid
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String  @map("product_id") @db.Uuid
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int     @default(1)

  @@unique([cartId, productId])
  @@map("cart_items")
}

model Order {
  id       String        @id @default(uuid()) @db.Uuid
  buyerId  String        @map("buyer_id") @db.Uuid
  buyer    BuyerProfile  @relation(fields: [buyerId], references: [userId])
  sellerId String        @map("seller_id") @db.Uuid
  seller   SellerProfile @relation(fields: [sellerId], references: [userId])

  subtotal       Decimal   @db.Decimal(12, 2)
  discountId     String?   @map("discount_id") @db.Uuid
  discount       Discount? @relation(fields: [discountId], references: [id])
  discountAmount Decimal   @default(0.00) @map("discount_amount") @db.Decimal(12, 2)
  deliveryFee    Decimal   @map("delivery_fee") @db.Decimal(12, 2)
  taxAmount      Decimal   @default(0.00) @map("tax_amount") @db.Decimal(12, 2)
  finalTotal     Decimal   @map("final_total") @db.Decimal(12, 2)

  deliveryMethod DeliveryMethod @map("delivery_method")
  status         OrderStatus    @default(BEING_PACKED)

  items         OrderItem[]
  statusHistory OrderStatusHistory[]
  deliveryJob   DeliveryJob?

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  @@map("orders")
}

model OrderItem {
  id        String  @id @default(uuid()) @db.Uuid
  orderId   String  @map("order_id") @db.Uuid
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String  @map("product_id") @db.Uuid
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int

  priceAtPurchase Decimal @map("price_at_purchase") @db.Decimal(10, 2)

  @@map("order_items")
}

model OrderStatusHistory {
  id        String      @id @default(uuid()) @db.Uuid
  orderId   String      @map("order_id") @db.Uuid
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    OrderStatus
  createdAt DateTime    @default(now()) @map("created_at") @db.Timestamp(6)

  @@map("order_status_history")
}

model DeliveryJob {
  id      String @id @default(uuid()) @db.Uuid
  orderId String @unique @map("order_id") @db.Uuid
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  driverId String?        @map("driver_id") @db.Uuid
  driver   DriverProfile? @relation(fields: [driverId], references: [userId])

  pickedUpAt  DateTime? @map("picked_up_at") @db.Timestamp(6)
  completedAt DateTime? @map("completed_at") @db.Timestamp(6)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  @@index([driverId])
  @@map("delivery_jobs")
}

model WalletTransaction {
  id          String          @id @default(uuid()) @db.Uuid
  buyerId     String          @map("buyer_id") @db.Uuid
  buyer       BuyerProfile    @relation(fields: [buyerId], references: [userId], onDelete: Cascade)
  amount      Decimal         @db.Decimal(12, 2)
  type        TransactionType
  description String
  createdAt   DateTime        @default(now()) @map("created_at") @db.Timestamp(6)

  @@map("wallet_transactions")
}

model Discount {
  id             String       @id @default(uuid()) @db.Uuid
  code           String       @unique @db.VarChar(50)
  type           DiscountType
  amount         Decimal      @db.Decimal(12, 2)
  expiryDate     DateTime     @map("expiry_date") @db.Timestamp(6)
  remainingUsage Int?         @map("remaining_usage")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  orders    Order[]

  @@map("discounts")
}
